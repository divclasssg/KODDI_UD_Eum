{
  "name": "koddi-medical-interview-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": "22.17.0",
    "npm": "11.18.0"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build --webpack",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "test:icons": "node --test tests/icon-*-contract.test.mjs",
    "test:e2e": "next build --webpack && playwright test",
    "test:actual": "vitest run --config vitest.actual.config.ts",
    "test:tokens": "node --test tests/design-token-contract.test.mjs",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
