# Provider mode: deterministic local mock or an explicitly configured Vertex endpoint.
MEDGEMMA_MODE=mock

# Server-only Vertex AI configuration. Never commit credential values or key files.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
MEDGEMMA_ENDPOINT_ID=
MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
MEDGEMMA_TIMEOUT_MS=30000
MEDGEMMA_MAX_REQUEST_BYTES=

# Keep photo input hidden until the conditional U8 gate passes.
NEXT_PUBLIC_ENABLE_PHOTO_INPUT=false
