# 공급자 모드는 결정론적 모의 응답 또는 인증된 Modal 엔드포인트만 허용한다.
MEDGEMMA_MODE=mock
MEDGEMMA_MODEL_ID=google/medgemma-1.5-4b-it
MEDGEMMA_TIMEOUT_MS=60000
MEDGEMMA_MAX_REQUEST_BYTES=8192
MODAL_MEDGEMMA_ENDPOINT_URL=
MODAL_PROXY_TOKEN_ID=
MODAL_PROXY_TOKEN_SECRET=
DEMO_ALLOWED_ORIGIN=http://127.0.0.1:3000
DEMO_HMAC_SECRET=
MEDGEMMA_ACTUAL_DISABLED=1

# 상태 fixture 주소는 로컬 시각·접근성 검증에만 사용한다.
INTERVIEW_FIXTURE_MODE=0
